{
  "dashboard": {
    "id": null,
    "uid": "database-monitoring",
    "title": "Database Monitoring",
    "tags": ["staging", "database"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "PostgreSQL Up",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [{"expr": "pg_up"}]
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Active Connections",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [{"expr": "sum(pg_stat_activity_count)"}]
      },
      {
        "id": 3,
        "type": "timeseries",
        "title": "Query Duration",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [{"expr": "rate(pg_stat_activity_max_tx_duration[5m])"}]
      }
    ]
  }
}
