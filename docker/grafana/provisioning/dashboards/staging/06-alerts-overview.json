{
  "dashboard": {
    "id": null,
    "uid": "alerts-overview",
    "title": "Alerts Overview",
    "tags": ["staging", "alerts"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "type": "alertlist",
        "title": "Firing Alerts",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 0},
        "show": "current",
        "sortOrder": 1,
        "stateFilter": {"firing": true, "pending": true}
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Total Active Alerts",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [{"expr": "count(ALERTS{alertstate=\"firing\"})"}]
      },
      {
        "id": 3,
        "type": "stat",
        "title": "P0 Alerts",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [{"expr": "count(ALERTS{alertstate=\"firing\",severity=\"P0\"})"}]
      }
    ]
  }
}
