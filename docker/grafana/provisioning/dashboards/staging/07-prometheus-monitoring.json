{
  "dashboard": {
    "id": null,
    "uid": "prometheus-monitoring",
    "title": "Prometheus Monitoring",
    "tags": ["staging", "prometheus"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "Targets Up",
        "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
        "targets": [{"expr": "count(up == 1)"}]
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Targets Down",
        "gridPos": {"h": 4, "w": 8, "x": 8, "y": 0},
        "targets": [{"expr": "count(up == 0)"}]
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Total Targets",
        "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
        "targets": [{"expr": "count(up)"}]
      },
      {
        "id": 4,
        "type": "timeseries",
        "title": "Scrape Duration",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [{"expr": "scrape_duration_seconds"}]
      },
      {
        "id": 5,
        "type": "timeseries",
        "title": "Samples Scraped",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [{"expr": "rate(scrape_samples_scraped[5m])"}]
      }
    ]
  }
}
