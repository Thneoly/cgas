{
  "dashboard": {
    "id": null,
    "uid": "application-metrics",
    "title": "Application Metrics",
    "tags": ["staging", "application"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "App Uptime",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [{"expr": "app_uptime_seconds"}]
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Total Requests",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [{"expr": "app_requests_total"}]
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Total Errors",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [{"expr": "app_errors_total"}]
      },
      {
        "id": 4,
        "type": "stat",
        "title": "Error Rate",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [{"expr": "app_errors_total / app_requests_total * 100"}]
      }
    ]
  }
}
