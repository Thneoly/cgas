{
  "dashboard": {
    "id": null,
    "uid": "system-overview",
    "title": "System Overview",
    "tags": ["staging", "system"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "CPU Usage",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [{"expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)"}]
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Memory Usage",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [{"expr": "avg((1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100)"}]
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Disk Usage",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [{"expr": "avg(100 - (node_filesystem_avail_bytes / node_filesystem_size_bytes) * 100)"}]
      },
      {
        "id": 4,
        "type": "stat",
        "title": "Uptime",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [{"expr": "node_time_seconds - node_boot_time_seconds"}]
      }
    ]
  }
}
