{
  "dashboard": {
    "id": null,
    "uid": "alpha-overview",
    "title": "Alpha Environment Overview",
    "tags": ["alpha"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "CPU Usage",
        "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
        "targets": [{"expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)"}]
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Memory Usage",
        "gridPos": {"h": 4, "w": 8, "x": 8, "y": 0},
        "targets": [{"expr": "avg((1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100)"}]
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Targets Up",
        "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
        "targets": [{"expr": "count(up == 1)"}]
      },
      {
        "id": 4,
        "type": "timeseries",
        "title": "CPU Usage Over Time",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [{"expr": "100 - (avg by(instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)"}]
      },
      {
        "id": 5,
        "type": "timeseries",
        "title": "Memory Usage Over Time",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [{"expr": "avg by(instance) ((1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100)"}]
      }
    ]
  }
}
